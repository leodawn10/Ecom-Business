# ─── BINA ECom environment ───────────────────────────────────────────────
# Copy this file to `.env.local` and replace the DEMO values with your own.
# `.env.local` is gitignored — NEVER commit real keys. All values below are
# fake placeholders so this file is safe to keep in a public repo.

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Supabase (backend: catalog, newsletter, orders) ───
# Both values are browser-safe (the anon/publishable key is protected by Row
# Level Security + the place_order() RPC). Get yours at supabase.com.
NEXT_PUBLIC_SUPABASE_URL="https://demo-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_DEMO0000demo1111KEY2222replace3333"

# Direct Postgres (optional — migrations via Supabase CLI / Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/bina?schema=public"

# Auth (NextAuth) — roadmap
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Cloudinary (media + 3D asset hosting) — roadmap
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Razorpay ───
# Key id is public (used by the browser Checkout widget). The secret is
# server-only AND must also be stored in Supabase: app_secrets('razorpay_key_secret')
# so payment-signature verification happens inside Postgres. Use TEST keys first.
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_DEMO0000demo1111"
RAZORPAY_KEY_ID="rzp_test_DEMO0000demo1111"
RAZORPAY_KEY_SECRET="DEMOdemoRazorpaySecret0000replace0000"
# Optional webhook backstop — also store as app_secrets('razorpay_webhook_secret')
RAZORPAY_WEBHOOK_SECRET="DEMO_webhook_secret_replace_me"

# Stripe — roadmap (international)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Redis (cache / rate limit) — roadmap
REDIS_URL="redis://localhost:6379"
